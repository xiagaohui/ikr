{
  "name": "ikr",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:api": "pnpm --filter @ikr/api dev",
    "build": "pnpm --filter @ikr/db build && pnpm --filter @ikr/ai build && pnpm --filter @ikr/shared build && pnpm --filter @ikr/api build",
    "db:push": "pnpm --filter @ikr/db db:push",
    "db:migrate": "pnpm --filter @ikr/db db:migrate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "drizzle-orm": "^0.30.10",
    "playwright-core": "^1.58.2",
    "postgres": "^3.4.8"
  }
}
