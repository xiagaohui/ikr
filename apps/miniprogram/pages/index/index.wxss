.page {
  padding: 0 0 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部 */
.header {
  padding: 60rpx 32rpx 32rpx;
  background: #ffffff;
}
.header-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.header-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 提问框 */
.input-section {
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.input-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1a1a1a;
}
.query-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1a1a1a;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}
.input-placeholder {
  color: #bbbbbb;
}
.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}
.char-count {
  font-size: 22rpx;
}
.send-btn {
  background: #e0e0e0;
  color: #999;
  border-radius: 10rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  line-height: 1.4;
  min-height: unset;
  transition: all 0.2s;
}
.send-btn.active {
  background: #1a1a1a;
  color: #ffffff;
}
.send-btn::after { border: none; }

/* 知识库状态 */
.status-section {
  margin: 16rpx 24rpx 0;
}
.status-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.status-label { font-size: 26rpx; color: #666; }
.status-value { font-size: 26rpx; font-weight: 600; }
.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}
.progress-fill.cold  { background: #ffb74d; }
.progress-fill.warm  { background: #4caf50; }
.status-hint { font-size: 22rpx; }

/* 冷启动引导 */
.cold-start {
  margin: 16rpx 24rpx 0;
}
.cold-start-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.cold-start-desc {
  font-size: 24rpx;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
.cold-start-steps { display: flex; gap: 16rpx; }
.step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.step-num {
  width: 48rpx;
  height: 48rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}
.step-text { font-size: 22rpx; color: #666; text-align: center; }

/* 最近收录 */
.recent-section { margin-top: 32rpx; padding: 0 24rpx; }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.section-title { font-size: 28rpx; font-weight: 600; }
.section-more  { font-size: 24rpx; }

.item-card {
  margin-bottom: 12rpx;
  border-radius: 16rpx;
}
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.item-title {
  font-size: 26rpx;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-meta { font-size: 22rpx; }
