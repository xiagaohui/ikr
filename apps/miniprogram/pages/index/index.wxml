<view class="page">

  <!-- 顶部区域 -->
  <view class="header">
    <view class="header-title">IKR</view>
    <view class="header-sub">你的个人决策顾问</view>
  </view>

  <!-- 提问框 -->
  <view class="input-section card">
    <view class="input-label">今天遇到什么问题？</view>
    <textarea
      class="query-input"
      placeholder="描述你的问题或决策场景..."
      placeholder-class="input-placeholder"
      value="{{query}}"
      bindinput="onQueryInput"
      maxlength="500"
      auto-height
    />
    <view class="input-footer">
      <view class="char-count text-secondary">{{query.length}}/500</view>
      <button
        class="send-btn {{query.length > 0 ? 'active' : ''}}"
        bindtap="onSubmit"
        disabled="{{loading || query.length === 0}}"
      >
        <text wx:if="{{loading}}">思考中...</text>
        <text wx:else>发送</text>
      </button>
    </view>
  </view>

  <!-- 知识库状态 -->
  <view class="status-section card" wx:if="{{cardCount > 0}}">
    <view class="status-row">
      <text class="status-label">知识库</text>
      <text class="status-value">{{cardCount}} 个知识点</text>
    </view>
    <view class="progress-bar">
      <view
        class="progress-fill {{isColdStart ? 'cold' : 'warm'}}"
        style="width: {{isColdStart ? (cardCount / 20 * 100) : 100}}%"
      />
    </view>
    <text class="status-hint text-secondary" wx:if="{{isColdStart}}">
      再积累 {{20 - cardCount}} 个知识点，个性化建议开始生效
    </text>
    <text class="status-hint text-secondary" wx:else>
      个性化建议已生效，继续积累效果更好
    </text>
  </view>

  <!-- 冷启动引导 -->
  <view class="cold-start card" wx:if="{{cardCount === 0}}">
    <view class="cold-start-title">开始积累你的知识库</view>
    <view class="cold-start-desc text-secondary">
      在微信里把文章转发给 IKR 服务号，我会自动消化提炼
    </view>
    <view class="cold-start-steps">
      <view class="step">
        <text class="step-num">1</text>
        <text class="step-text">关注 IKR 服务号</text>
      </view>
      <view class="step">
        <text class="step-num">2</text>
        <text class="step-text">转发感兴趣的文章</text>
      </view>
      <view class="step">
        <text class="step-num">3</text>
        <text class="step-text">遇到问题来这里问</text>
      </view>
    </view>
  </view>

  <!-- 最近收录 -->
  <view class="recent-section" wx:if="{{recentItems.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近收录</text>
      <text class="section-more text-secondary" bindtap="onViewLibrary">全部 ›</text>
    </view>
    <view class="item-list">
      <view
        class="item-card card"
        wx:for="{{recentItems}}"
        wx:key="id"
        bindtap="onItemTap"
        data-id="{{item.id}}"
      >
        <view class="item-header">
          <text class="item-title">{{item.title || '无标题'}}</text>
          <text class="tag tag-{{item.primaryType}}">{{typeLabel(item.primaryType)}}</text>
        </view>
        <view class="item-meta text-secondary">
          {{formatTime(item.createdAt)}}
          <text wx:if="{{item.cardCount}}"> · {{item.cardCount}} 个知识点</text>
        </view>
      </view>
    </view>
  </view>

</view>
