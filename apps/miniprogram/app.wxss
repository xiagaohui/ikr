/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 通用按钮 */
.btn-primary {
  background: #1a1a1a;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

.btn-secondary {
  background: #f0f0f0;
  color: #1a1a1a;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

/* 文字颜色 */
.text-secondary {
  color: #999999;
  font-size: 24rpx;
}

.text-primary {
  color: #1a1a1a;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  background: #f0f0f0;
  color: #666666;
}

.tag-argument  { background: #fff3e0; color: #e65100; }
.tag-operation { background: #e8f5e9; color: #2e7d32; }
.tag-fact      { background: #e3f2fd; color: #1565c0; }
.tag-narrative { background: #f3e5f5; color: #6a1b9a; }
